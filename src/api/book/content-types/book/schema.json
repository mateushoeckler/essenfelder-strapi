{
  "kind": "collectionType",
  "collectionName": "books",
  "info": {
    "singularName": "book",
    "pluralName": "books",
    "displayName": "Book",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string",
      "required": true
    },
    "Cover": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "Description": {
      "type": "text"
    },
    "Checklist": {
      "type": "json"
    },
    "Bibliography": {
      "type": "json"
    },
    "Evaluation": {
      "type": "json"
    },
    "course": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course.course",
      "inversedBy": "books"
    },
    "Color": {
      "type": "string",
      "regex": "^\\#[\\dABCDEFabcdef]{6}$",
      "required": true
    },
    "Order": {
      "type": "integer"
    },
    "lessons": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::lesson.lesson",
      "mappedBy": "book"
    },
    "pdf": {
      "allowedTypes": [
        "files"
      ],
      "type": "media",
      "multiple": false
    },
    "pdf_Botao": {
      "type": "string",
      "default": "PDF"
    }
  }
}
